# Dev-only overrides. НЕ хранить здесь секреты приложения —
# seed-фразы и приватные ключи пользователя живут только в RAM (Secret<T>).

# URL GitHub API для Chain Registry (можно переопределить для тестов)
COSMOS_CHAIN_REGISTRY_URL=https://api.github.com/repos/cosmos/chain-registry/contents

# Путь к SQLite БД при запуске из исходников
COSMOS_CHECKER_DB_PATH=./cosmos-checker.sqlite

# Уровень логирования (tracing): error | warn | info | debug | trace
RUST_LOG=cosmos_checker=debug,info
